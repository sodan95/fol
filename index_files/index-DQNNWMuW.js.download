stsYet:"Одоогоор нийтлэл байхгүй байна. Дараа дахин шалгана уу.",noPostsInCategory:'"{{category}}" ангилалд нийтлэл байхгүй байна.'},gme={notFound:"Нийтлэл олдсонгүй",backToBlog:"Блог руу буцах",allPosts:"Бүх нийтлэл"},vme={title:"Имэйлийн тохиргоо",missingToken:"Захиалга цуцлах токен дутуу байна.",invalidToken:"Хүчингүй эсвэл хугацаа нь дууссан токен.",validateError:"Захиалга цуцлах холбоосыг баталгаажуулах боломжгүй байлаа.",validating:"Таны холбоосыг баталгаажуулж байна…",confirmText:"Lumos College-ийн имэйлээс захиалга цуцлахыг хүсэж байвал доор дарна уу.",confirmButton:"Захиалгыг цуцлахыг баталгаажуулах",processing:"Боловсруулж байна…",doneTitle:"Таны захиалга цуцлагдлаа.",doneText:"Та энэ хаягаар Lumos College-оос имэйл хүлээн авахгүй болно.",alreadyTitle:"Захиалга цуцлагдсан",alreadyText:"Энэ имэйл хаяг захиалгагүй болсон байна.",errorTitle:"Хүсэлтийг боловсруулах боломжгүй",networkError:"Сүлжээний алдаа. Дахин оролдоно уу.",somethingWrong:"Ямар нэг зүйл буруу болсон байна."},yme={campusLabel:"Кампус",companiesLabel:"Компаниуд",applicationsLabel:"өргөдөл",comeToLumos:"Lumos-д ирээрэй",applyNow:"Одоо хүсэлт илгээнэ үү",whereInnovation:"Инноваци бүтээгдэх газар",utahCompaniesText1:"Microsoft, Google, Meta, Amazon, Adobe зэрэг дэлхийн томоохон компаниуд Юта мужид үйл ажиллагаа явуулж байгаа нь тус бүс нутгийг Америкийн Нэгдсэн Улс дахь хамгийн чухал технологийн төвүүдийн нэг болгосон. Энэхүү экосистемийн төвд англи хэл сурах нь дэлхийн инновацид ойр байх гэсэн үг юм.",utahCompaniesText2:"Юта мужид 1 тэрбум гаруй долларын үнэлгээтэй 20 гаруй том компани байдаг нь тус мужийг АНУ-ын хамгийн хурдацтай хөгжиж буй инновацийн төвүүдийн нэг болгож байна!",seattle:{heroTitle:"Кампус - Seattle",name:"SEATTLE",intro:"Манай Seattle кампус нь Puget Sound бүсийн зүүн талд, Redmond хотын төвд байрладаг. Шинэ Redmond хотын төвийн хөнгөн галт тэрэгний зогсоолоос богинохон алхаад л оюутнууд тав тухтай тээвэр, ойрхон кафе, дэлгүүрүүд, мөн Seattle метрополийн бүс рүү хурдан нэвтрэх боломжтой. Энэ нь англи хэл сурахын зэрэгцээ томоохон технологийн компаниуд болон их дээд сургуулиудад ойр байхыг хүсдэг сурагчдын хувьд маш сайн суурь юм.",companiesText:"Microsoft, Amazon, Boeing, Google зэрэг дэлхийн тэргүүлэгч компаниудын өлгий нутаг болох Seattle нь технологи, инновацийн чиглэлээр дэлхийн түвшний төв юм. Энд англи хэл сурах нь оюутнуудыг програм хангамж, сансар судлал, биотехнологи, тоглоом зэрэг анхдагч салбаруудад ойртуулна.",features:{amenities:{title:"Оюутнуудад ээлтэй тав тухтай байгууламжууд",desc:"Redmond Town Center, цэцэрлэгт хүрээлэн, хоолны газар, чухал үйлчилгээнүүдээс холгүй."},flexible:{title:"Уян хатан хичээлийн цагууд",desc:"Өглөө, үдээс хойш, оройн цагийн сонголтууд ангиуд бүрдэх үед."},transit:{title:"Нийтийн тээврийн хүртээмж",desc:"Шинэ Redmond хотын төвийн хөнгөн галт тэрэгний зогсоол руу богинохон алхах; SR-520 болон I-405-тай хурдан холбогдоно."},housing:{title:"Орон сууцны зөвлөгөө",desc:"Ойролцоох орон сууц, гэр бүлийн хамгаалалтын сонголтуудын эх үүсвэр."}}},orem:{heroTitle:"Кампус - Orem",name:"OREM",intro:"Прово хотын ойролцоох Юта мужийн төв хэсэгт байрлах манай Orem кампус нь Юта мужийн хамгийн хурдацтай хөгжиж буй бүс нутгуудын нэгэнд оюутнуудад дулаахан, найрсаг уур амьсгалыг санал болгодог. Энэ нь Юта мужийн Orem-д англи хэл сурахын зэрэгцээ их дээд сургууль, гадаа амралт зугаалга, дэлгүүрүүдэд ойрхон, тайван, аюулгүй амьдрах орчинд таатай байх төгс газар юм.",features:{social:{title:"Сурах, нийгэмшихийн талбайнууд",desc:"Сурах, нийгэмших зориулалттай газрууд"},university:{title:"Их сургуулийн төв байршилтай",desc:"Юта Вэллэй Их Сургууль (UVU) болон Брайхам Янг Их Сургууль (BYU)-ын ойролцоо тав тухтай байршилтай"},transit:{title:"Нийтийн тээвэр ба тав тухтай хүртээмж",desc:"Нийтийн тээвэр болон ойролцоох тав тухтай газруудад хүрэх боломжтой"},housing:{title:"Хямд орон сууц",desc:"Боломжийн үнэтэй орон сууц, айлд амьдрах сонголтууд"}}},saltLake:{heroTitle:"Кампус - Salt Lake City",name:"SALT LAKE CITY",intro:"Хотын төвийн ойролцоо байрлах манай Salt Lake City кампус нь оюутнуудад Юта мужид англи хэл сурах төгс орчныг санал болгодог. Соёлын дурсгалт газрууд, ресторанууд, дэлгүүрүүд, нийтийн тээврээр хүрээлэгдсэн энэхүү кампус нь Salt Lake City-д англи хэл сурахын зэрэгцээ хотын идэвхтэй амьдралыг мэдрэхийг хүсдэг оюутнуудад тохиромжтой.",features:{tech:{title:"Технологиор сайжруулсан хичээлийн танхимууд",desc:"Мультимедиа технологи бүхий орчин үеийн хичээлийн танхимууд"},facilities:{title:"Оюутны байгууламжууд",desc:"Оюутны лаборатори, цайны газар, хичээл хийх талбайнууд"},transit:{title:"Тохиромжтой тээвэр",desc:"Автобус, TRAX болон хотын төвийн тав тухтай газруудад амархан хүрэх боломжтой"},housing:{title:"Ойролцоох орон сууцны сонголтууд",desc:"Ойролцоох орон сууц, айлд амьдрах сонголтууд"}}}},xme={tooltip:"WhatsApp дээр чатлах",choose:"WhatsApp-аа сонгоно уу",brazil:"Бразилийн дугаар",international:"Бусад орны дугаар"},bme={nav:Whe,common:Ghe,home:Khe,about:Yhe,programs:Qhe,admissions:Jhe,tuition:Zhe,englishCenter:Xhe,faq:eme,library:tme,bookstore:nme,support:rme,login:sme,resetPassword:ame,profile:ime,admin:ome,student:lme,teacher:cme,footer:ume,consultation:dme,notFound:hme,homepageDemo:mme,libraryPage:pme,blog:fme,blogPost:gme,unsubscribe:vme,campuses:yme,whatsapp:xme};qn.use(rM).use(pW).init({resources:{en:{translation:Dce},pt:{translation:lue},es:{translation:Mue},ja:{translation:hde},fr:{translation:zde},ko:{translation:ghe},zh:{translation:Hhe},mn:{translation:bme}},fallbackLng:"en",interpolation:{escapeValue:!1},detection:{order:["localStorage","navigator"],caches:["localStorage"]}});const sM=e=>{document.documentElement.lang=e};sM(qn.language);qn.on("languageChanged",sM);UP(document.getElementById("root")).render(i.jsx(Ble,{}));
