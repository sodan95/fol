nfo:"연락처 정보",location:"위치",phone:"전화",email:"이메일",onlineResources:"온라인 자료",access:"액세스",libraryServices:"도서관 서비스",ourCollection:"저희 컬렉션",loginToSchedule:"사서와의 연구 상담을 예약하려면 로그인하십시오.",resources:{linr:{title:"LINR 액세스",desc:"도서관 정보 네트워크 자료에 액세스"},general:{title:"일반 온라인 도서관",desc:"Project Gutenberg, Open Library, Google Books, Internet Archive에 액세스"},academic:{title:"학술 및 연구 도서관",desc:"DOAB, ERIC, JSTOR Open Access, CORE, ScienceOpen"},textbooks:{title:"교과서 및 강의 자료",desc:"무료 교과서를 위한 OpenStax, LibreTexts, Bookboon"}},services:{computer:"컴퓨터 및 인쇄 서비스",studyRooms:"학습실 (예약 필수)",wifi:"전역 무료 Wi-Fi",research:"연구 지원",citation:"인용 및 작문 지원",quiet:"조용한 학습 공간"},stats:{books:"도서",journals:"저널",ebooks:"전자책",databases:"데이터베이스"}},dhe={metaTitle:"블로그 | Lumos College",metaDescription:"Lumos College의 소식, 통찰력 및 업데이트.",title:"블로그",subtitle:"Lumos College 커뮤니티의 이야기, 뉴스 및 통찰력.",all:"모두",noPostsYet:"아직 게시된 게시물이 없습니다. 잠시 후에 다시 확인해주세요.",noPostsInCategory:'"{{category}}"에 게시물이 아직 없습니다.'},hhe={notFound:"게시물을 찾을 수 없습니다",backToBlog:"블로그로 돌아가기",allPosts:"모든 게시물"},mhe={title:"이메일 환경설정",missingToken:"구독 취소 토큰이 없습니다.",invalidToken:"유효하지 않거나 만료된 토큰입니다.",validateError:"구독 취소 링크를 확인할 수 없습니다.",validating:"링크 확인 중…",confirmText:"Lumos College 이메일 수신을 취소하려면 아래를 클릭하십시오.",confirmButton:"구독 취소 확인",processing:"처리 중…",doneTitle:"구독이 취소되었습니다.",doneText:"이 주소로는 더 이상 Lumos College의 이메일을 받지 않으실 것입니다.",alreadyTitle:"이미 구독 취소됨",alreadyText:"이 이메일 주소는 더 이상 구독되어 있지 않습니다.",errorTitle:"요청 처리 불가",networkError:"네트워크 오류입니다. 다시 시도하십시오.",somethingWrong:"문제가 발생했습니다."},phe={campusLabel:"캠퍼스",companiesLabel:"기업",applicationsLabel:"지원",comeToLumos:"Lumos로 오세요",applyNow:"지금 지원하기",whereInnovation:"혁신이 시작되는 곳",utahCompaniesText1:"Microsoft, Google, Meta, Amazon, Adobe와 같은 글로벌 대기업들이 유타에서 운영되면서 이 지역은 미국에서 가장 중요한 기술 허브 중 하나가 되었습니다. 이러한 생태계의 중심에서 영어를 공부한다는 것은 글로벌 혁신에 가까이 있다는 것을 의미합니다.",utahCompaniesText2:"유타에는 10억 달러 이상의 가치를 가진 20개 이상의 강력한 기업들이 있으며, 이는 유타를 미국에서 가장 빠르게 성장하는 혁신 허브 중 하나로 만듭니다!",seattle:{heroTitle:"캠퍼스 - 시애틀",name:"시애틀",intro:"저희 시애틀 캠퍼스는 퓨젯 사운드 지역 동쪽의 다운타운 레드몬드에 위치해 있습니다. 새로운 다운타운 레드몬드 경전철역에서 도보로 가까운 거리에 있어 학생들은 편리한 대중교통, 인근 카페와 쇼핑, 그리고 더 넓은 시애틀 메트로 지역으로의 빠른 접근성을 누릴 수 있습니다. 영어를 공부하면서 주요 기술 기업 및 대학과 가까이 지내고 싶은 학습자에게 훌륭한 기반이 됩니다.",companiesText:"Microsoft, Amazon, Boeing, Google과 같은 세계적인 선도 기업들의 본거지인 시애틀은 기술과 혁신의 세계적인 허브입니다. 이곳에서 영어를 공부하는 학생들은 소프트웨어, 항공우주, 생명공학, 게임과 같은 선구적인 산업에 가까워집니다.",features:{amenities:{title:"학생 친화적인 편의시설",desc:"레드몬드 타운 센터, 공원, 식당, 필수 서비스에서 몇 걸음 거리."},flexible:{title:"유연한 수업 시간",desc:"코호트가 형성되면 오전, 오후, 저녁 옵션 제공."},transit:{title:"대중교통 접근성",desc:"새로운 다운타운 레드몬드 경전철역에서 도보로 가까운 거리; SR-520 및 I-405와의 빠른 연결."},housing:{title:"숙소 안내",desc:"인근 숙소 및 홈스테이 옵션에 대한 자료."}}},orem:{heroTitle:"캠퍼스 - 오렘",name:"오렘",intro:"프로보 근처 유타 카운티 중심부에 위치한 저희 오렘 캠퍼스는 유타에서 가장 빠르게 성장하는 지역 중 한 곳에서 따뜻하고 친근한 분위기를 학생들에게 제공합니다. 대학, 야외 오락 및 쇼핑과 가까운 평화롭고 안전한 커뮤니티를 즐기면서 오렘, 유타에서 영어를 배우기에 완벽한 장소입니다.",features:{social:{title:"학습 및 사교 공간",desc:"학습 및 사교를 위한 전용 공간"},university:{title:"최고의 대학 위치",desc:"Utah Valley University (UVU) 및 Brigham Young University (BYU)와 가까운 편리한 위치"},transit:{title:"대중교통 및 편의시설 접근성",desc:"대중교통 및 인근 편의시설 이용 가능"},housing:{title:"예산 친화적인 숙소",desc:"저렴한 숙소 및 홈스테이 옵션"}}},saltLake:{heroTitle:"캠퍼스 - 솔트레이크 시티",name:"솔트레이크 시티",intro:"다운타운 중심부에 가까이 위치한 솔트레이크 시티 캠퍼스는 유타에서 영어를 공부하기에 완벽한 환경을 학생들에게 제공합니다. 문화적 랜드마크, 레스토랑, 쇼핑, 대중교통으로 둘러싸인 이 캠퍼스는 솔트레이크 시티에서 영어를 배우면서 활동적인 도시 경험을 원하는 학생들에게 이상적입니다.",features:{tech:{title:"기술 강화 교실",desc:"멀티미디어 기술을 갖춘 현대적인 교실"},facilities:{title:"학생 시설",desc:"학생 실습실, 식당 및 학습 공간"},transit:{title:"편리한 교통",desc:"버스, TRAX 및 다운타운 편의시설로의 쉬운 접근"},housing:{title:"인근 숙소 옵션",desc:"인근 숙소 및 홈스테이 옵션"}}}},fhe={tooltip:"WhatsApp으로 채팅",choose:"WhatsApp 선택",brazil:"브라질 번호",international:"기타 국가 번호"},ghe={nav:qde,common:Bde,home:Vde,about:Hde,programs:Wde,admissions:Gde,tuition:Kde,englishCenter:Yde,faq:Qde,library:Jde,bookstore:Zde,support:Xde,login:ehe,resetPassword:the,profile:nhe,admin:rhe,student:she,teacher:ahe,footer:ihe,consultation:ohe,notFound:lhe,homepageDemo:che,libraryPage:uhe,blog:dhe,blogPost:hhe,unsubscribe:mhe,campuses:phe,whatsapp:fhe},vhe={home:"主页",about:"关于我们",admissions:"招生",programs:"College",tuition:"学费",faq:"常见问题",library:"图书馆",bookstore:"书店",support:"支持",blog:"博客",englishCenter:"英语中心",studentPortal:"学生门户",teacherArea:"教师专区",admin:"管理员",signIn:"登录",signOut:"退出",profile:"个人资料设置",pages:"页面",portals:"门户"},yhe={lumosCollege:"Lumos College",learnMore:"了解更多",applyNow:"立即申请",startApplication:"开始申请",submit:"提交",cancel:"取消",save:"保存",loading:"加载中...",error:"错误",success:"成功"},xhe={welcome:"欢迎来到 Lumos College",motto:"创新激情",heroDesc:"您在商业和科技领域的成功之路从这里开始。",explorePrograms:"探索课程",studentPortal:"学生门户",teacherArea:"教师专区",whyChoose:"为什么选择 Lumos College？",whyChooseDesc:"我们提供支持性的学习环境，课程旨在满足您的职业目标。",qualityEducation:"优质教育",qualityEducationDesc:"副学士学位旨在为您在职业生涯中的成功和晋升做好准备。",expertFaculty:"专家教师",expertFacultyDesc:"向致力于您学业卓越的经验丰富的专业人士学习。",studentSupport:"学生支持",studentSupportDesc:"全面的支持服务，助您在整个学习旅程中取得成功。",careerFocused:"职业导向",careerFocusedDesc:"与行业需求和实际应用相结合的课程。",noEnglishTitle:"没有英语基础？没问题！",noEnglishDesc:"英语水平尚未达到要求？请从 Lumos English Center 的 ESL 课程开始。一旦您达到所需水平，便可无缝过渡到大学课程并攻读学位。",businessPrograms:"商业课程",businessTracks:"8个专业方向",businessDesc:"在您感兴趣的领域获得专业知识，为商业原理打下坚实基础。",viewBusinessPrograms:"查看商业课程",techPrograms:"科技课程",techTracks:"10个专业方向",techDesc:"掌握尖端科技技能，为科技行业热门职业做好准备。",viewTechPrograms:"查看科技课程",intensiveEslTag:"Lumos English Center",intensiveEslTitle:"强化英语准备课程",intensiveEslDesc:"从零开始打好英语基础。我们的 ESL 课程为您准备大学水平的课程，以便您能够无缝过渡到您的学位课程。",paralegalTag:"应用科学副学士",paralegalTitle:"律师助理学位",paralegalDesc:"无需法律学位即可开启法律职业生涯。我们的律师助理课程为您提供在律师事务所、公司和政府机构工作所需的法律知识和实践技能。",readyToStart:"准备好开始您的旅程了吗？",readyToStartDesc:"加入 Lumos College，迈出实现您的教育和职业目标的第一步。",applyNow:"立即申请",haveQuestions:"有问题？",haveQuestionsDesc:"我们的招生团队随时为您解答有关课程、学费或申请流程的任何问题。填写表格，我们将在24小时内回复您。",phone:"电话",email:"电子邮件",location:"地点",getInTouch:"联系我们",responseTime:"我们将在24小时内回复"},bhe={title:"关于 Lumos College",tagline:"创新激情",subtitle:"自1995年以来，通过优质教育赋能未来",mission:"我们的使命",missionText:"Lumos College 致力于通过可及、创新和实用的教育，照亮商业和技术领域的成功之路。我们为学生提供必要的知识、技能和道德基础，使其在快速发展的行业中茁壮成长，培养他们在数字时代终身学习和负责任领导的承诺。",vision:"我们的愿景",visionText:"Lumos College 旨在成为商业和技术教育领域的卓越灯塔，以培养出不仅技术精湛、而且道德高尚、适应能力强的毕业生而闻名。我们设想未来，我们的校友将走在推动行业、社区及其他领域积极变革的最前沿。",values:"我们的价值观",value1Title:"卓越",value1Desc:"我们追求教育和学生成功的最高标准。",value2Title:"社区",value2Desc:"为所有学生建立一个支持性和包容性的学习环境。",value3Title:"创新",value3Desc:"拥抱现代教学方法和尖端技术。",value4Title:"以学生为中心",value4Desc:"将学生的成长和成就置于我们一切工作的核心。",storyTitle:"Lumos College 的故事",storyP1:"Lumos College 成立于2024年，源于 Gilbert 和 Sheila Gaertner 共同的梦想——一个由多年国际教育奉献和对全球学生面临挑战的深刻理解所塑造的梦想。",storyP2:"自2008年以来，作为 Lumos Language School 的创始人兼董事，Gilbert 和 Sheila 已帮助超过12,000名国际学生在美国开启他们的学术之旅。通过他们的工作，他们亲眼见证了那些为了追求高等教育和更好机会而离开家园的学生所展现出的决心、才华和潜力。",storyP3:"然而，他们也看到了障碍。",storyP4:"国际学生在申请大学时常常面临重重障碍。入学要求可能复杂且令人望而生畏。即使被录取，学生通常也被归类为州外居民，需要支付高得多的学费。对于许多有才华和勤奋的个人来说，这些经济负担使得高等教育遥不可及。",storyP5:"认识到这一差距，Gilbert 和 Sheila 设想了一个不同的愿景——一个为国际学生量身定制的机构。一个提供公平学费、强大学术标准和热情环境的机构，让学生真正拥有归属感。",storyP6:"这个愿景成为了 Lumos College。",storyP7:"Lumos College 最初只有一小群学生，开设了商业和技术副学士学位课程——这些课程旨在提供实用知识、卓越学术和明确的职业和教育晋升途径。",storyP8:"自成立以来，Lumos College 始终秉持着一个简单而强大的使命：在不损害学术严谨性的前提下，让优质高等教育触手可及。",storyP9:"展望未来，Lumos College 计划在2027年开始接受持有 F-1 学生签证的国际学生。这一扩展将为全美数千名寻求扎实、支持性和高质量高等教育起点的国际学生提供一个新的、经济实惠的选择。",storyP10:"Lumos College 不仅仅是一所院校——它是一个承诺的延续：开启大门，创造机会，并提供一条雄心与机遇相遇的路径。",yearsExcellence:"卓越年限",industryPartners:"行业合作伙伴",campusLife:"校园生活",campus1Title:"现代化教室",campus1Desc:"配备最新技术的现代化学习空间",campus2Title:"合作空间",campus2Desc:"专为团队合作和创新而设计的开放区域",campus3Title:"技术实验室",campus3Desc:"设备齐全的实验室，提供动手学习体验",joinCommunity:"加入我们的社区",joinCommunityDesc:"准备好开始您的 Lumos College 之旅了吗？联系我们，我们将帮助您迈出下一步。",getStartedToday:"今天就开始",respondWithin24:"我们将在24小时内回复"},whe={title:"我们的课程",subtitle:"从18个专业副学士学位课程中选择，旨在助您在当今竞争激烈的就业市场中取得成功。",businessDegree:"工商管理文学副学士",businessSpecialties:"8个专业方向可选",accreditationPending:"ACCSC认证待批",businessDegreeDesc:"Lumos College 的工商管理文学副学士 (AA) 课程为核心商业原理和实践奠定坚实基础，致力于培养学生在各种商业领域中充满活力的职业生涯。",specializations:"专业方向：",programHighlights:"课程亮点：",techDegree:"计算机科学理学副学士",techSpecialties:"10个专业方向可选",techDegreeDesc:"Lumos College 的计算机科学理学副学士 (AS) 课程为学生提供在不断发展的科技行业取得成功所需的T基本技能。",paralegalDegree:"律师助理文学副学士",paralegalTrack:"法律领域职业方向",paralegalDesc:"Lumos College 的律师助理文学副学士 (A.A.) 课程为学生在法律领域提供有意义的职业生涯。",whatYouLearn:"您将学习什么：",careerPaths:"潜在职业路径：",paralegalNote:"律师助理和法律支持专业人员使法院系统高效运行，协助企业应对复杂的法规，并确保司法系统提供公平的正当程序。如果您对影响美国生活各个方面（从政府到非营利组织再到商业）的职业感兴趣，那么 Lumos College 的律师助理研究课程是正确的开始。",studentBenefits:"学生福利",planJourney:"规划您的学业旅程",planJourneyDesc:"使用我们的互动学位规划器来规划您的课程表，跟踪您的进度，并确保您在正确的毕业道路上。",openPlanner:"打开学位规划器",applyNow:"立即申请",applyNowDesc:"准备好迈出下一步了吗？立即开始申请，加入 Lumos College 社区。",startApplication:"开始申请",requestInfo:"索取课程信息",businessHighlights:["63学分课程","灵活的排课选择","结合行业需求的课程","职业安置援助"],techHighlights:["60学分课程","动手实验室经验","行业认证","实习机会"],paralegalHighlights:["文学副学士 (A.A.)","法律、政府和政策基础","从第一天起就培养实用法律技能","以职业为中心的课程","通往法律研究学士学位的途径"],businessSpecsList:[{name:"会计",desc:"专注于财务报告、审计、税务和财务分析。",detail:"会计培养你记录、分类和解读财务信息的能力。课程涵盖财务会计、管理会计、税务、审计以及会计软件（QuickBooks、Excel）。毕业生可担任会计员、记账员、税务准备员或初级审计员，并可继续考取 CPA 资格。"},{name:"市场营销",desc:"涵盖广告、市场调研、消费者行为和数字营销策略。",detail:"市场营销教你研究受众、产品定位以及在数字与传统渠道开展活动。涵盖消费者行为、品牌、SEO/SEM、社交媒体、内容策略和分析。常见职位：市场协调员、品牌助理、数字营销人员、社媒专员。"},{name:"管理",desc:"强调领导力、组织行为、人力资源和战略规划。",detail:"管理专注于团队和运营的规划、组织与领导。你将学习组织行为、领导力、项目管理、运营和基础战略。毕业生通常从团队负责人、主管、项目协调员或运营专员起步。"},{name:"创业",desc:"提供创办和管理自己企业所需的技能和知识。",detail:"创业培养你识别机会、验证创意并创建新业务的能力。课程包括商业模式设计、精益创业、基础财务、小型企业营销和运营。结果可包括启动初创企业、经营家族生意或加入早期团队。"},{name:"国际商务",desc:"专注于全球贸易、国际营销和跨文化管理。",detail:"国际商务探索企业如何跨境运营。你将学习全球贸易、国际营销、跨文化管理、外汇基础以及全球供应链。岗位包括进出口协调员、国际销售或跨国公司分析师。"},{name:"供应链管理",desc:"涉及物流、运营管理、采购和供应链策略。",detail:"供应链管理研究商品与服务如何从供应商流向客户。课程涵盖采购、物流、库存、需求计划与 ERP 系统。毕业生可担任采购员、物流协调员、供应计划员或运营分析师。"},{name:"人力资源管理",desc:"涵盖招聘、员工关系、薪酬和福利管理。",detail:"人力资源关注组织中的“人”的层面：招聘、入职、薪酬、福利、培训、员工关系和劳动法基础。岗位包括 HR 通才、招聘专员、培训协调员、人事运营专员。"},{name:"信息系统管理",desc:"结合商业和技术，专注于管理信息系统和IT资源。",detail:"信息系统管理将商业与技术连接起来。你将学习组织如何选择、实施和管理 IT 系统——包括数据库、ERP、云工具及网络安全基础——以支持业务目标。岗位包括 IT 业务分析师、系统协调员或初级 IT 经理。"}],techSpecsList:[{name:"网络管理",desc:"设计、实施和管理局域网、广域网和云网络。",detail:"网络管理涵盖计算机之间的通信。你将学习 TCP/IP、路由与交换、无线、VPN、防火墙以及故障排除——与 CompTIA Network+ 或 Cisco CCNA 等认证对接。岗位包括网络技术员、网络管理员和初级系统工程师。"},{name:"网络安全",desc:"使用安全协议和数字取证保护系统、网络和数据免受网络威胁。",detail:"网络安全专注于保护系统、网络和数据免遭攻击。你将学习网络基础、威胁分析、密码学基础、道德黑客、应急响应和合规。常见入门岗位：SOC 分析师、初级安全工程师或 IT 安全技术员。"},{name:"技术支持和帮助台",desc:"协助最终用户解决技术问题。",detail:"技术支持与帮助台帮助你为终端用户诊断和解决硬件、软件、网络问题。课程涵盖操作系统、工单系统、远程支持和客户服务，与 CompTIA A+ 对接。岗位包括帮助台技术员、IT 支持专员和桌面支持。"},{name:"数据库管理",desc:"设计、开发和管理数据库，重点是 SQL 和数据挖掘。",detail:"数据库管理教你设计、构建和维护关系型数据库。你将使用 SQL、数据建模、规范化、备份与报表工具，并接触数据挖掘入门。岗位包括初级 DBA、SQL 开发者和数据分析师。"},{name:"系统管理",desc:"管理和维护服务器、操作系统和 IT 基础设施。",detail:"系统管理涵盖服务器、操作系统（Windows/Linux）、虚拟化、存储和 IT 基础设施的管理。课程包括用户管理、基础脚本、监控和备份/恢复。岗位包括系统管理员、IT 运维技术员和基础设施支持。"},{name:"网页开发",desc:"构建和维护网站和网络应用程序，包括前端和后端。",detail:"网页开发涵盖网站与 Web 应用构建。课程包括 HTML、CSS、JavaScript、现代框架（如 React）、后端 API、数据库、版本控制（Git）和部署。毕业生可担任前端、后端或全栈开发者。"},{name:"云计算",desc:"管理云服务、虚拟化、存储和安全。",detail:"云计算教你在 AWS、Azure 和 Google Cloud 等平台上部署和运行应用。课程涵盖虚拟化、容器（Docker）、Serverless、网络和云安全。岗位包括云支持、初级云工程师和 DevOps 技术员。"},{name:"软件开发",desc:"专注于编程语言和软件工程原理。",detail:"软件开发教你设计、构建和维护应用程序。你将学习编程基础、数据结构、面向对象设计、版本控制（Git）、测试以及敏捷工作流。岗位包括初级软件工程师、应用开发者和 QA 自动化工程师。"},{name:"信息系统管理",desc:"整合 IT 和业务以优化组织信息系统。",detail:"信息系统管理将技术与业务流程整合。你将学习系统分析、项目管理、数据库以及 IT 如何支持运营、营销和财务。岗位包括 IT 业务分析师、系统协调员和项目支持专员。"},{name:"IT 项目管理",desc:"使用敏捷和 Scrum 从规划到执行管理 IT 项目。",detail:"IT 项目管理教你规划、执行和交付技术项目。课程涵盖敏捷与 Scrum、项目计划、范围与风险管理、利益相关者沟通以及 Jira 等工具。岗位包括项目协调员、初级项目经理和 Scrum master 后备人选。"}],paralegalLearnList:["刑法和法院程序","法律研究和写作","撰写证词和法律文件","房地产交易和产权调查","民事诉讼基础","道德和职业责任","政府机构和法律政策","合同法和商业法规"],paralegalCareersList:["律师助理","法律助理","法律文员","法律秘书","索赔理赔员","合规官"],studentBenefitsList:[{name:".edu 邮箱",desc:"享受各种服务的折扣"},{name:"在线练习",desc:"随时随地完成作业"},{name:"职业支持",desc:"为您提供教育和职业目标方面的帮助"},{name:"法律咨询",desc:"F-1 签证办理协助"},{name:"忠诚计划",desc:"从第二学期开始享受$200折扣"},{name:"补课",desc:"不错过任何内容 — 补上错过的课程"},{name:"推荐计划",desc:"推荐朋友可获得现金奖励"},{name:"SEVP 认证",desc:"获得政府认证的 F-1 学生签证"}]},She={title:"入学申请",subtitle:"在 Lumos College 开启您的学术之旅",intro:"Lumos College 致力于提供可及、实用且以职业为导向的优质高等教育。我们的招生流程旨在简化，让您专注于为商业和技术领域的未来做准备。",generalReqs:"一般入学要求",generalReqsDesc:"申请 Lumos College 入学，申请人必须满足以下基本要求：",registrationProcess:"注册流程",welcomeApp:"欢迎使用 Lumos College 申请",appUsedFor:"此申请适用于 Lumos College 和 Lumos English Center。",appExplain1:"作为申请流程的一部分，您将被要求选择您在 Lumos College 的意向专业。如果您已精通英语或已参加官方英语水平测试（如 TOEFL），我们的团队将审核您的成绩。",appExplain2:"如果您需要在开始大学水平课程之前提高英语水平，请不要担心 — 我们将与您合作制定一个扎实、个性化的学业计划。",fourSteps:"申请流程包括四个步骤，每个步骤的详细说明如下。",step1Title:"填写申请表",step1List:["个人信息","意向学习课程","联系方式"],step1Desc:"所有申请人都必须通过在线招生门户提交完整的申请。",step1OutsideUS:"立即开始",step1InsideUS:"美国境内学生申请",step2Title:"英语水平测试 (EPT)",step2List:["在 EPT 门户网站创建账户","招生部门将向您发送测试代码","使用测试代码在线参加英语水平测试"],step2Desc:"所有申请人都必须参加英语水平测试。请在下方注册以创建您的帐户，招生部门将提供您的测试代码。",step2Btn:"注册英语测试",step3Title:"英语课程或大学课程",step3Desc:"根据您的 EPT 结果，Lumos College 将确定以下情况之一：",step3Sufficient:"达到足够水平：",step3SufficientDesc:"您将被授权直接注册大学课程。",step3Additional:"需要额外准备：",step3AdditionalDesc:"您将被推荐在进入大学水平课程之前参加 Lumos English Center 的课程。",step4Title:"个人陈述",step4List:["您为什么想进入 Lumos College","您的学业和职业目标","您选择的课程如何与您的未来计划相符"],step4Desc:"这份陈述有助于招生团队更好地了解每位学生的动机和愿望。",step4Btn:"完成个人陈述",ds160Title:"填写您的签证信息表格 DS-160",ds160P1:"作为申请过程的一部分，我们将要求您回答一些重要问题，这些问题将帮助我们准备您的美国签证申请。",ds160P2:"此信息将用于填写 DS-160，这是美国政府要求 F-1 签证申请人填写的官方在线表格。",ds160P3:"DS-160 收集基本信息，例如您的个人信息、旅行史、教育背景。我们的团队将指导您完成此过程，并确保所有信息填写正确。",ds160Btn:"开始输入您的信息",transferReqs:"转学生附加要求",transferDesc:"从其他机构转学的学生还必须提供：",transferList:["所有曾就读机构的官方成绩单","课程描述（如需要进行转学分评估）"],transferNote:"转学分是否被接受取决于课程等效性和院校政策。",whyChoose:"为什么选择 Lumos College？",whyChooseDesc:"Lumos College 提供以职业为导向的副学士学位课程，旨在帮助学生在当今竞争激烈的就业市场中取得成功。",studentsBenefit:"学生受益于：",benefitsList:["实惠的学费","灵活的学习时间表","支持性的师资力量","以职业为核心的课程"],missionItalic:"我们的使命是提供可及、创新的教育，使学生能够建立成功的未来。",startToday:"今天就开始您的申请",firstStep:"迈出您未来的第一步。"},Che={title:"学费和费用",subtitle:"优质教育，价格实惠，透明公开。",theCosts:"费用",costsDesc:"Lumos College 以犹他州最低的学费之一提供卓越教育。对于 Lumos Language School EIP（英语强化课程）的学生，学费仅为每学分$134。学习12-18学分的学生每学期享受固定费率$1,608，这使得 Lumos College 成为那些希望最大限度地减少学生贷款的人的经济实惠选择。",estimatedBudget:"每学期预算估算",budgetCategory:"预算类别",oneSemester:"一学期",twoSemesters:"2026年春季和2026年秋季",summer:"2026年夏季",budgetNote:"国际学生需要提供$6,420（一学期）或$12,840（一学年）的个人经济资助证明。此文件是签发 I-20 表格所必需的。",budgetNoteLabel:"注：",budgetCategories:{tuition:"学费",fees:"杂费",housing:"食宿",books:"书籍/用品",transportation:"交通",misc:"其他",total:"总计"},paymentOptions:"付款方式",paymentPlans:"付款方式",paymentPlansDesc:"提供灵活的付款计划，可将费用分摊到整个学期",semesterPayment:"学期付款",semesterPaymentDesc:"每学期初一次性付清",financialAid:"经济援助",financialAidDesc:"探索奖学金、助学金和援助机会",affordablePrices:"实惠的价格",affordablePricesDesc:"Lumos College 致力于以实惠的价格提供卓越的教育，确保学生获得高质量的学习，而无须承担高等教育通常伴随的财政负担。下表对比了 Lumos College 与犹他州其他院校的学费和费用，突显了我们具有竞争力的价格和对可及性的承诺。",college:"大学",inStateTuition:"本州学生学费和杂费",suppliesBooks:"用品和书籍",comparisonNote:"显示部分院校。Lumos College 与犹他州其他大学相比，提供有竞争力的价格。",scholarships:"Lumos College 的奖学金",investingFuture:"投资您的未来",scholarshipsP1:"Lumos College 致力于通过提供各种奖学金来扩大高等教育的机会，这些奖学金旨在表彰学业成就、领导潜力，以及个人决心。",scholarshipsP2:"我们的奖学金有助于减轻大学的经济负担，同时奖励那些致力于教育和未来职业目标的学生。",scholarshipsP3:"大多数 Lumos College 奖学金以成绩为基础或参考经济需求，除非另有说明，所有被学院录取的申请人都会自动获得符合条件的奖学金。",scholarshipsP4:"奖学金名额有限，竞争激烈，最终奖励金额将在审查学生入学申请和支持文件后确定。",scholarshipProcess:"奖学金申请流程",scholarshipProcessDesc:"学生提交完整的入学申请后，将自动获得 Lumos College 大部分奖学金的考虑资格。奖学金评审过程通常包括：",scholarshipSteps:["提交入学申请","审查学术记录和成绩单","评估个人陈述","考虑奖学金资格标准"],scholarshipNotice:"奖学金获得者将作为录取决定过程的一部分收到通知。",importantNotes:"重要注意事项",importantNotesList:["奖学金名额有限，竞争激烈。","奖励不予保证，并需经机构审查。","学生必须保持令人满意的学业进展才能保持资格。","奖学金可每年续期，具体取决于资格和学业成绩。"],questionsAboutTuition:"对学费有疑问？",questionsDesc:"我们的招生团队随时为您解答投资问题并探索您的选择。",callUs:"致电我们",callHours:"周一至周四，蒙大拿时间上午9点至下午5点",emailUs:"给我们发电子邮件",emailResponse:"我们将在24小时内回复",scheduleConsultation:"安排咨询",startApplication:"开始申请",scholarshipsList:[{name:"Lumos 优秀奖学金",amount:"每年高达$3,000",desc:"表彰在学业上表现出色并有潜力在严谨的大学环境中取得成功的学生。",criteria:["以往学业表现","个人陈述质量","对职业发展的承诺","入学申请的整体实力"]},{name:"Lumos 机会奖学金",amount:"每年高达$2,500",desc:"支持那些尽管面临经济障碍但仍决心追求高等教育的学生。",criteria:["个人陈述和教育目标","坚韧不拔的毅力证明","学术准备和对成功的承诺"]},{name:"第一代奖学金",amount:"每年高达$2,500",desc:"授予其直系亲属中第一位上大学的学生。",criteria:["父母双方均未完成大学学位","直系亲属中第一位接受高等教育的学生"]},{name:"Lumos 全球学生奖学金",amount:"每年高达$2,500",desc:"提供给具有学术潜力并致力于多元全球学习环境的国际学生。",criteria:["学术背景","领导潜力","个人陈述","对全球和文化多样性的贡献"]},{name:"Lumos 领导力奖学金",amount:"每年高达$2,000",desc:"表彰在学业、职业或社区活动中表现出领导潜力的学生。",criteria:["社区服务","专业或创业计划","参与社团、组织或志愿工作","主动性和责任感的证明"]}]},jhe={title:"Lumos English Center",subtitle:"CEA（英语语言课程认证委员会）认证的 ESL 英语培训课程",methodology:"我们的教学方法：CLT",methodologySubtitle:"交际语言教学——行之有效的英语学习方法",methodologyDesc:"在 Lumos English Center，我们采用交际语言教学 (CLT) 方法——一种以学生为中心，侧重于真实交流的方法。学生通过互动课程、小组合作、角色扮演和真实材料，从第一天起就开始有意义地使用英语。",ourPrograms:"我们的英语课程",tuition:"学费",firstSemester:"第一学期：",subsequentSemesters:"后续学期：",extras:"+ 注册费 $120 • 教材免费",rowDuration:"时长",rowWeeklyHours:"每周学时",rowClassDays:"上课日",rowSchedule:"课表",rowFormat:"形式",rowPrerequisite:"先决条件",valSemesters6:"6个学期",valSemesters1:"1个学期",valHours18:"18 小时",valHours20:"20 小时",valHours22:"22 小时",valDaysMonThu:"周一至周四",valDaysMonTue:"周一/周二或周三/周四",valDaysMon:"仅周一",valScheduleMornEve:"上午或晚上",valFormatInPerson:"面授",valLevel6:"英语6级",skills:[{name:"阅读",desc:"练习来自教育和专业背景的真实文本。"},{name:"写作",desc:"通过作业和论文培养强大的书面沟通能力。"},{name:"口语",desc:"与英语母语人士练习，并获得发音反馈。"},{name:"听力",desc:"通过母语教师、真实材料和沉浸式学习提高听力。"},{name:"互动",desc:"小组合作、角色扮演和任务让学生积极使用英语。"},{name:"文化",desc:"课程强调文化背景，以培养真实生活中的自信和尊重。"}],regular:{title:"常规英语课程",tag:"F-1 签证 • 每周4天",desc:"旨在通过 CLT 方法帮助学生适应教育和专业环境。涵盖语法、阅读、写作、听力、口语和词汇发展。"},intensive:{title:"强化课程",tag:"F-1 签证 • 每周2天",desc:"作为 F-1 学生每周只需学习2天！优化您的学习时间，增加日常沉浸，并加速流利程度——让您有5天时间自由探索、旅行和享受生活。"},superIntensive:{title:"超强化课程",tag:"F-1 签证 • 每周1天",desc:"作为 F-1 学生每周只需学习1天！优化您的学习时间，增加日常沉浸，并加速流利程度。您将参加一天9小时的课程，其余时间可随时在学校实验室完成——时间安排非常灵活。"},toefl:{title:"TOEFL 备考课程",tag:"F-1 签证 • 等级6+",desc:"深入分析和强化练习 TOEFL 的所有四个部分：阅读、听力、口语和写作。包括带即时反馈和个性化提示的 TOEFL 考试模拟器。"},cefrTitle:"熟练度级别（与 CEFR 对齐）",cefrDesc:"Lumos 课程提供7个英语级别，从基础到高级。每个级别包括3门并发课程，分别是听力/口语、阅读/写作和语法/词汇——在一个学期内完成。",cefrPlacementNote:"学生根据入学前进行的英语分级测试被安排到适当的级别。",cefrLevels:[{name:"ESL 入门",cefr:"Pre-A1"},{name:"初级",cefr:"A1"},{name:"高级初级",cefr:"A2"},{name:"低中级",cefr:"B1"},{name:"高中级",cefr:"B2"},{name:"高级",cefr:"C1"}],studentBenefits:"学生福利",requestInformation:"索取信息",pathwayTitle:"您的美国高等教育之路",pathwayP1:"在Lumos，我们相信当英语学习与明确的学术和职业目标联系在一起时，效果最为显著。因此，我们的课程被设计为Lumos College综合路径的一部分。",pathwayP2:"学生无需孤立地学习英语，而是通过一个将英语语言发展与未来学术学习相结合的结构化计划开始他们的旅程。这种方法使学生能够：",pathwayBullet1:"在学术环境中建立扎实的英语水平",pathwayBullet2:"顺利过渡到大学水平课程",pathwayBullet3:"培养在美国取得长期成功所需的技能",pathwayBullet4:"使他们的学习与职业和教育目标保持一致",pathwayP3:"我们的路径模型反映了国际学生在美国教育系统中自然而然的进步方式——从语言准备开始，然后进入高等教育。",pathwayP4:"通过Lumos College申请，学生不仅是注册了一个英语课程，而且迈出了更广阔学术旅程的第一步。",admissionsTitle:"招生流程",admissionsIntro1:"在Lumos，学生通过Lumos College申请，并进入一个结构化的学术通道，旨在支持语言发展和未来的学业成功。",admissionsIntro2:"这意味着从一开始，学生不仅计划学习英语，还在为在美国的继续教育做准备。",howToApply:"如何申请",applyStep1Title:"提交申请",applyStep1Desc:"填写Lumos College申请表，提供您的个人和学术信息。",applyStep2Title:"提供所需文件",applyDoc1:"护照复印件",applyDoc2:"财力证明",applyDoc3:"学术记录（如果有）",applyStep3Title:"收到录取决定",applyStep3Desc:"一旦被录取，学生将收到一份Form I-20，其中包含他们的学习计划。",applyStep4Title:"准备签证面试",applyStep4Desc:"学生使用其录取文件申请F-1学生签证。",academicApproach:"我们的教学方法",academicApproachIntro:"我们的课程设计旨在为高等教育铺平道路，学生将：",approach1:"如果需要，从英语培训开始",approach2:"过渡到大学水平的课程",approach3:"在美国建立长期学术计划"},khe={title:"常见问题",subtitle:"查找有关我们的课程、入学和支持服务的常见问题解答。",commonQuestions:"常见问题",stillHaveQuestions:"还有疑问？",stillHaveQuestionsDesc:"我们的招生团队随时为您解答任何额外问题。",phone:"电话",email:"邮箱",items:[{q:"商业和技术副学士学位能从事哪些职业？",a:"毕业生可以从事会计、市场营销、管理、IT支持、网络安全、网页开发、数据库管理等职业。我们的课程为您提供入门级职位，并提供晋升机会。"},{q:"我将在此课程中培养哪些技能？",a:"您将培养与您所选的商业或技术专业相关的批判性思维、沟通、技术熟练程度、解决问题和领导力技能。"},{q:"是否有动手学习或实习的机会？",a:"是的，我们的课程包括实践性组成部分，如实验室工作、项目和实习机会，以在您的领域提供真实的经验。"},{q:"完成副学士学位后，我可以将学分转到四年制大学吗？",a:"是的，Lumos College 的课程旨在促进学分转学到四年制大学。我们的顾问可以帮助您规划转学途径。"},{q:"此课程为学生提供哪些支持服务？",a:"我们提供学业咨询、辅导、职业咨询、技术支持和个人发展资源，以帮助您取得成功。"},{q:"商业和技术副学士课程的总费用是多少？",a:"Lumos College 的学费为每学分$134，12-18学分每学期固定费用为$1,608。请访问我们的学费页面以获取完整的费用明细。"},{q:"学生是否有经济援助选择？",a:"是的，Lumos College 提供多种基于成绩和考虑需求的奖学金。所有被录取的学生都会自动获得符合条件的奖学金的考虑。"}]},_he={title:"图书馆",subtitle:"您在 Lumos College 获取知识、研究和学业成功的门户。",hours:"开放时间",contactInfo:"联系方式",onlineResources:"在线资源",access:"访问",libraryServices:"图书馆服务",ourCollection:"我们的馆藏",loginToSchedule:"请登录以预约与我们的图书馆员进行研究咨询。",hoursNote:"* 节假日和考试期间开放时间可能有所不同"},Nhe={title:"书店",subtitle:"您的学术之旅所需的教材、用品和资源。",textbooks:"教材",textbooksDesc:"所有课程和项目的必修及推荐教材。",supplies:"用品",suppliesDesc:"学习用品、实验材料和必要的学习工具。",merchandise:"商品",merchandiseDesc:"Lumos College 品牌服装、配饰和礼品。",comingSoon:"在线书店即将上线",comingSoonDesc:"我们的在线书店正在建设中。在此期间，请直接联系书店获取教材信息。"},Ehe={title:"学生支持服务",subtitle:"通过学术支持、辅导和咨询服务获得您所需的帮助。",technicalSupport:"技术支持",technicalSupportDesc:"获取有关技术问题、登录问题和平台导航的帮助。",tutoring:"辅导",tutoringDesc:"课程材料和备考的一对一辅导。",academicAdvising:"学业咨询",academicAdvisingDesc:"与顾问会面，进行课程规划、学位要求和职业指导。",available:"开放时间：周一至周五，上午9:00至下午5:00",loginNote:"请登录以预约支持服务。如果您没有帐户，请使用以下表格联系我们。",scheduleTechnical:"预约技术支持",scheduleTutoring:"预约辅导课程",scheduleAdvising:"预约学业咨询",pleaseLogin:"请登录以预约。",signInRequired:"需要登录",otherQuestions:"还有其他问题？",respondWithin24:"我们将在24小时内回复"},Phe={welcome:"欢迎来到 Lumos",signInOrCreate:"登录或创建账户",signIn:"登录",signUp:"注册",email:"电子邮件",password:"密码",fullName:"全名",signingIn:"正在登录...",creatingAccount:"正在创建账户...",forgotPassword:"忘记密码？",enterEmailFirst:"请先输入您的电子邮件",checkEmail:"检查您的电子邮件",resetLinkSent:"重置密码链接已发送。",signInFailed:"登录失败",signUpFailed:"注册失败",welcomeBack:"欢迎回来！",accountCreated:"账户已创建！",verifyEmail:"请检查您的电子邮件以验证您的帐户。",resendVerification:"未收到验证邮件？重新发送",verificationSent:"验证邮件已发送",verificationSentDesc:"请检查您的收件箱以确认您的账户。"},The={invalidLink:"无效链接",invalidLinkDesc:"此密码重置链接无效或已过期。请申请新的链接。",backToLogin:"返回登录",setNewPassword:"设置新密码",enterNewPassword:"在下方输入您的新密码",newPassword:"新密码",confirmPassword:"确认密码",updating:"正在更新...",updatePassword:"更新密码",passwordsDontMatch:"密码不匹配",passwordTooShort:"密码必须至少6个字符",errorResetting:"重置密码时出错",passwordUpdated:"密码更新成功！"},Ahe={title:"个人资料设置",avatar:"头像",avatarDesc:"上传个人资料图片",upload:"上传",uploading:"正在上传...",displayName:"显示名称",displayNa